{
  "name": "hrm-backend",
  "version": "1.0.0",
  "description": "HRM Backend API (JavaScript only)",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "prod": "pm2 start ecosystem.config.cjs --env production",
