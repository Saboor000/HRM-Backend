{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",

    "types": ["node"],

    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true,

    "allowJs": true,
    "checkJs": false
  },
  "include": ["src/**/*"]
}